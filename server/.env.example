# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Your Runn API key — found under Settings → API in the Runn app (admin only)
RUNN_API_KEY=your_runn_api_key_here

# Runn base URL — use https://api.us.runn.io for US region accounts
RUNN_HOST=https://api.runn.io

# Raintool (Hailstorm) base URL — no API key needed, proxy bypasses CORS
RAINTOOL_HOST=https://hailstorm.frostdesigngroup.com
