rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Access config — read/write by any authenticated user
    match /config/access {
      allow read, write: if request.auth != null;
    }

    // Per-board requests — read/write by authenticated users with valid shape
    match /boards/{boardId}/requests/{requestId} {
      allow read:             if request.auth != null;
      allow delete:           if request.auth != null;
      allow create, update:   if request.auth != null
                              && request.resource.data.id == requestId
                              && request.resource.data.status in ['open', 'on-hold', 'closed'];
    }

    // Trello cache — read by authenticated users, written only by Cloud Functions (Admin SDK bypasses rules)
    match /cache/{document} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Per-user preferences (hidden boards, pass tracking) — each user owns their own doc
    match /userPrefs/{userEmail} {
      allow read, write: if request.auth != null && request.auth.token.email == userEmail;
    }
  }
}
